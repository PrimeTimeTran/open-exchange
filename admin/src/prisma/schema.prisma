  invitationToken String?          @unique
  apiKeys         ApiKey[]
  subscriptions   Subscription[]
  status          MembershipStatus @default(active)

  membershipCreatedBy Membership[] @relation("createdByMembership")
  membershipUpdatedBy Membership[] @relation("updatedByMembership")
  apiKeyCreatedBy ApiKey[] @relation("createdByMembership")
  apiKeyUpdatedBy ApiKey[] @relation("updatedByMembership")

  accountCreatedBy Account[] @relation("createdByMembership") 
  accountUpdatedBy Account[] @relation("updatedByMembership") 
  accountArchivedBy Account[] @relation("archivedByMembership")

  walletCreatedBy Wallet[] @relation("createdByMembership") 
