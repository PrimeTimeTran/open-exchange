  importHash            String?     @unique

  userId          String           @db.Uuid
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String?
  lastName        String?
  fullName        String?
  avatars         Json?
  roles           String[]
  invitationToken String?          @unique
  apiKeys         ApiKey[]
  subscriptions   Subscription[]
  status          MembershipStatus @default(active)

  membershipCreatedBy Membership[] @relation("createdByMembership")
  membershipUpdatedBy Membership[] @relation("updatedByMembership")
  apiKeyCreatedBy ApiKey[] @relation("createdByMembership")
  apiKeyUpdatedBy ApiKey[] @relation("updatedByMembership")

  postCreatedBy Post[] @relation("createdByMembership") 
  postUpdatedBy Post[] @relation("updatedByMembership") 
  postArchivedBy Post[] @relation("archivedByMembership")

  commentCreatedBy Comment[] @relation("createdByMembership") 
  commentUpdatedBy Comment[] @relation("updatedByMembership") 
  commentArchivedBy Comment[] @relation("archivedByMembership")

  orderCreatedBy Order[] @relation("createdByMembership") 
  orderUpdatedBy Order[] @relation("updatedByMembership") 
  orderArchivedBy Order[] @relation("archivedByMembership")

  articleCreatedBy Article[] @relation("createdByMembership") 
  articleUpdatedBy Article[] @relation("updatedByMembership") 
  articleArchivedBy Article[] @relation("archivedByMembership")

  itemCreatedBy Item[] @relation("createdByMembership") 
  itemUpdatedBy Item[] @relation("updatedByMembership") 
  itemArchivedBy Item[] @relation("archivedByMembership")

  chatCreatedBy Chat[] @relation("createdByMembership") 
  chatUpdatedBy Chat[] @relation("updatedByMembership") 
  chatArchivedBy Chat[] @relation("archivedByMembership")

  chateeCreatedBy Chatee[] @relation("createdByMembership") 
  chateeUpdatedBy Chatee[] @relation("updatedByMembership") 
  chateeArchivedBy Chatee[] @relation("archivedByMembership")

  messageCreatedBy Message[] @relation("createdByMembership") 
  messageUpdatedBy Message[] @relation("updatedByMembership") 
  messageArchivedBy Message[] @relation("archivedByMembership")

  assetCreatedBy Asset[] @relation("createdByMembership") 
  assetUpdatedBy Asset[] @relation("updatedByMembership") 
  assetArchivedBy Asset[] @relation("archivedByMembership")

  accountCreatedBy Account[] @relation("createdByMembership") 
  accountUpdatedBy Account[] @relation("updatedByMembership") 
  accountArchivedBy Account[] @relation("archivedByMembership")

  instrumentCreatedBy Instrument[] @relation("createdByMembership") 
  instrumentUpdatedBy Instrument[] @relation("updatedByMembership") 
  instrumentArchivedBy Instrument[] @relation("archivedByMembership")

  ledgerEventCreatedBy LedgerEvent[] @relation("createdByMembership") 
  ledgerEventUpdatedBy LedgerEvent[] @relation("updatedByMembership") 
  ledgerEventArchivedBy LedgerEvent[] @relation("archivedByMembership")

  ledgerEntryCreatedBy LedgerEntry[] @relation("createdByMembership") 
  ledgerEntryUpdatedBy LedgerEntry[] @relation("updatedByMembership") 
  ledgerEntryArchivedBy LedgerEntry[] @relation("archivedByMembership")

  tradeCreatedBy Trade[] @relation("createdByMembership") 
  tradeUpdatedBy Trade[] @relation("updatedByMembership") 
  tradeArchivedBy Trade[] @relation("archivedByMembership")

  tradeFillCreatedBy TradeFill[] @relation("createdByMembership") 
  tradeFillUpdatedBy TradeFill[] @relation("updatedByMembership") 
  tradeFillArchivedBy TradeFill[] @relation("archivedByMembership")
  posts Post[] @relation("posts_user")

  comments Comment[] @relation("comments_user")

  articles Article[] @relation("articles_user")

  chats Chatee[] @relation("chats_user")

  messages Message[] @relation("messages_sender")

  orders Order[] @relation("orders_user")


  @@unique([id, tenantId])
  @@unique([userId, tenantId])
}

enum SubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

enum SubscriptionMode {
  user
  tenant
  membership
  disabled
}

model Subscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String?  @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  membershipId         String?            @db.Uuid
  membership           Membership?        @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  userId               String             @db.Uuid
  user                 User               @relation(fields: [userId], references: [id])
  mode                 SubscriptionMode
  isCancelAtEndPeriod  Boolean            @default(false)
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
}

