  ledgerEntryArchivedBy LedgerEntry[] @relation("archivedByMembership")

  tradeCreatedBy Trade[] @relation("createdByMembership") 
  tradeUpdatedBy Trade[] @relation("updatedByMembership") 
  tradeArchivedBy Trade[] @relation("archivedByMembership")

  fillCreatedBy Fill[] @relation("createdByMembership") 
  fillUpdatedBy Fill[] @relation("updatedByMembership") 
  fillArchivedBy Fill[] @relation("archivedByMembership")

  postCreatedBy Post[] @relation("createdByMembership") 
  postUpdatedBy Post[] @relation("updatedByMembership") 
  postArchivedBy Post[] @relation("archivedByMembership")

  commentCreatedBy Comment[] @relation("createdByMembership") 
  commentUpdatedBy Comment[] @relation("updatedByMembership") 
  commentArchivedBy Comment[] @relation("archivedByMembership")

  articleCreatedBy Article[] @relation("createdByMembership") 
  articleUpdatedBy Article[] @relation("updatedByMembership") 
  articleArchivedBy Article[] @relation("archivedByMembership")

  chatCreatedBy Chat[] @relation("createdByMembership") 
  chatUpdatedBy Chat[] @relation("updatedByMembership") 
  chatArchivedBy Chat[] @relation("archivedByMembership")

  chateeCreatedBy Chatee[] @relation("createdByMembership") 
  chateeUpdatedBy Chatee[] @relation("updatedByMembership") 
  chateeArchivedBy Chatee[] @relation("archivedByMembership")

  messageCreatedBy Message[] @relation("createdByMembership") 
