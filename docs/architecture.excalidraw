    {
      "id": "VwTrJJltWpOmCNNhZBv0Z",
      "type": "text",
      "x": 1169.647243743369,
      "y": 1158.0724897847342,
      "width": 296.8477478027344,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 938633996,
      "version": 1931,
      "versionNonce": 1737730444,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770232068967,
      "link": null,
      "locked": false,
      "text": "Provides low-latency access to\nfrequently used or recent data for\nMarketplace, Matching, Ledger, and\nWeb Client.\n\nStores hot assets, session info, and\ntransient computation results to\nreduce load on Postgres.\n\nServices read from/write to Redis for\nspeed, falling back to Postgres for\nauthoritative data when needed.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "cAaK6-puQrA1voD9WFHjb",
      "originalText": "Provides low-latency access to frequently used or recent data for Marketplace, Matching, Ledger, and Web Client.\n\nStores hot assets, session info, and transient computation results to reduce load on Postgres.\n\nServices read from/write to Redis for speed, falling back to Postgres for authoritative data when needed.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5TPfKcuc1tYgWSAzVtY0F",
      "type": "diamond",
      "x": 1027.9133073748285,
      "y": 141.62710065099895,
      "width": 630.6282361309974,
      "height": 602.7459046516474,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": {
        "type": 2
      },
      "seed": 118040972,
      "version": 1930,
      "versionNonce": 2095742092,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "eG8od_w1I81Mbp17UwDV_"
        }
      ],
      "updated": 1770232063466,
      "link": null,
      "locked": false
    },
    {
      "id": "eG8od_w1I81Mbp17UwDV_",
      "type": "text",
      "x": 1195.878502393906,
      "y": 332.8135768139108,
      "width": 294.38372802734375,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0K",
      "roundness": null,
      "seed": 1908676620,
      "version": 2098,
      "versionNonce": 618776844,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770232319197,
      "link": null,
      "locked": false,
      "text": "Acts as the authoritative store for\ntrades, orders, listings, and account\nbalances.\n\nServices (Marketplace, Matching,\nLedger, Web Client) persist and query\ndata here for accuracy and durability.\n\nEnsures data integrity, transactional\nconsistency, and historical record\nkeeping across the system.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "5TPfKcuc1tYgWSAzVtY0F",
      "originalText": "Acts as the authoritative store for trades, orders, listings, and account balances.\n\nServices (Marketplace, Matching, Ledger, Web Client) persist and query data here for accuracy and durability.\n\nEnsures data integrity, transactional consistency, and historical record keeping across the system.",
      "autoResize": true,
      "lineHeight": 1.25
    },
