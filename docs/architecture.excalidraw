      "seed": 1903821836,
      "version": 1425,
      "versionNonce": 122864780,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770231496901,
      "link": null,
      "locked": false,
      "text": "Web client queries Ledger for account\nbalances, transaction history, and\ntrade confirmations.\n\nLedger provides authoritative, up-to-\ndate records to ensure users see\naccurate financial data.\n\nThis interaction keeps the user\ninterface consistent with the actual\nstate of accounts.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "It8P-GFdr4gA6dJ4XzbR2",
      "originalText": "Web client queries Ledger for account balances, transaction history, and trade confirmations.\n\nLedger provides authoritative, up-to-date records to ensure users see accurate financial data.\n\nThis interaction keeps the user interface consistent with the actual state of accounts.",
      "autoResize": true,
      "lineHeight": 1.25
    },
