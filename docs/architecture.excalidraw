    },
    {
      "id": "7RPWa629VWzeiivteu_mC",
      "type": "text",
      "x": -771.7244175157851,
      "y": -25.394565349566392,
      "width": 299.0237121582031,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aq",
      "roundness": null,
      "seed": 878861748,
      "version": 1228,
      "versionNonce": 1621768076,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770231496901,
      "link": null,
      "locked": false,
      "text": "Provides the web client with real-time\nand historical price data across asset\nclasses.\n\nSupplies data at configurable time\nintervals (1 minute → 1 day) for\nspecific symbols/assets.\n\nServes as the authoritative source\nfor market catalog and pricing.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "f9PlzQalPM9ltp3k9Yy3a",
      "originalText": "Provides the web client with real-time and historical price data across asset classes.\n\nSupplies data at configurable time intervals (1 minute → 1 day) for specific symbols/assets.\n\nServes as the authoritative source for market catalog and pricing.",
      "autoResize": true,
      "lineHeight": 1.25
    },
