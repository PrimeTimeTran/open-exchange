    },
    {
      "id": "V4plRZ77rUNgm67llmPXk",
      "type": "text",
      "x": 2271.386306470975,
      "y": 684.2180116831767,
      "width": 286.2077331542969,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0R",
      "roundness": null,
      "seed": 406769844,
      "version": 2313,
      "versionNonce": 653658636,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770232353731,
      "link": null,
      "locked": false,
      "text": "Redis caches hot/recent asset data\nand user session info to minimize\ndatabase load.\n\nPostgres stores persistent,\nauthoritative records for trades,\norders, and account balances.\n\nServices check Redis first for fast\naccess, then fall back to Postgres\nwhen data isn’t in memory, ensuring\nboth speed and consistency.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "xz0O0SlDW_Dnug_39uEjt",
      "originalText": "Redis caches hot/recent asset data and user session info to minimize database load.\n\nPostgres stores persistent, authoritative records for trades, orders, and account balances.\n\nServices check Redis first for fast access, then fall back to Postgres when data isn’t in memory, ensuring both speed and consistency.",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ],
