    {
      "id": "qfOs4ppdAd7tTemPHX_95",
      "type": "text",
      "x": -768.8204410753555,
      "y": 1682.303784233721,
      "width": 293.21575927734375,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
