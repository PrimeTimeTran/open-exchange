    {
      "id": "g7LL0C1Jaxv_WolIMJoye",
      "type": "text",
      "x": 211.89030086074558,
      "y": 768.2242779796069,
      "width": 303.05572509765625,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "al",
      "roundness": null,
      "seed": 406427188,
      "version": 1307,
      "versionNonce": 1222754060,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770231635058,
      "link": null,
      "locked": false,
      "text": "Marketplace provides current prices\nand market conditions to Matching so\ntrades execute at valid levels.\n\nMatching may query Marketplace for\nprice limits, spreads, or special order\ntypes (e.g., stop-loss, market orders).\n\nThey coordinate to ensure orders are\nmatched fairly and efficiently based on\nlive market data.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "HX3JQB_niYNgamx2unpVZ",
      "originalText": "Marketplace provides current prices and market conditions to Matching so trades execute at valid levels.\n\nMatching may query Marketplace for price limits, spreads, or special order types (e.g., stop-loss, market orders).\n\nThey coordinate to ensure orders are matched fairly and efficiently based on live market data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
