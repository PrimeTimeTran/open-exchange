    {
      "id": "v7Vo_4Odh6eq7wQikTxkd",
      "type": "text",
      "x": -768.772436924965,
      "y": 775.2751061202206,
      "width": 293.1197509765625,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
