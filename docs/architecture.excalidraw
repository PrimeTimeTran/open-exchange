    },
    {
      "id": "tYyZ6XAK1zvkfvhoxV9Qr",
      "type": "text",
      "x": 211.0982781556674,
      "y": 1706.26545447754,
      "width": 304.6397705078125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ao",
      "roundness": null,
      "seed": 1793114932,
      "version": 1427,
      "versionNonce": 937233036,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770231635058,
      "link": null,
      "locked": false,
      "text": "Matching sends executed trades to\nthe Ledger to record transactions and\nupdate account balances.\n\nLedger ensures consistency and\ndurability, preventing double-spends or\ninvalid balances.\n\nThey work together to keep the trade\nlifecycle accurate and auditable.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "07ONqkLyBy9y6EI13Mp7m",
      "originalText": "Matching sends executed trades to the Ledger to record transactions and update account balances.\n\nLedger ensures consistency and durability, preventing double-spends or invalid balances.\n\nThey work together to keep the trade lifecycle accurate and auditable.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f9PlzQalPM9ltp3k9Yy3a",
      "type": "diamond",
      "x": -937.3696204694329,
      "y": -226.58104151247824,
      "width": 630.6282361309974,
      "height": 602.7459046516474,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
