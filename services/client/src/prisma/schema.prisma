  updatedByMembershipId String?     @default(dbgenerated("NULLIF((current_setting('app.current_membership_id'::text)), '')::uuid")) @db.Uuid
  updatedByMembership   Membership? @relation("updatedByMembership", fields: [updatedByMembershipId], references: [id], onDelete: SetNull)
  archivedAt             DateTime?   @db.Timestamptz(3)
  archivedByMembershipId String?     @db.Uuid
  archivedByMembership   Membership? @relation("archivedByMembership", fields: [archivedByMembershipId], references: [id], onDelete: SetNull)
  importHash            String?     @unique

  amount Decimal @db.Decimal(72, 0)
  status String?
  chain String?
  txHash String?
  fromAddress String?
  confirmations Int?
  requiredConfirmations Int?
  detectedAt DateTime? @db.Timestamptz(3)
  confirmedAt DateTime? @db.Timestamptz(3)
  creditedAt DateTime? @db.Timestamptz(3)
  meta Json?
  accountId String? @db.Uuid
  account Account? @relation("account_deposits", fields: [accountId], references: [id])

  assetId String? @db.Uuid
  asset Asset? @relation("asset_deposits", fields: [assetId], references: [id])



  @@unique([id, tenantId])
